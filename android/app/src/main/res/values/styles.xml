<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme — тёмная, без ActionBar, прозрачные панели -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">#0a0a0a</item>
        <item name="colorPrimaryDark">#0a0a0a</item>
        <item name="colorAccent">#39FF14</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowBackground">#FF0a0a0a</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="AppTheme">
        <item name="android:windowBackground">@drawable/splash</item>
    </style>
</resources>
